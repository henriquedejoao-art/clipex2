rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening & Global Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Helper to check for a connection test doc
    match /test/connection {
      allow get: if true;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.createdAt is number && 
             data.subscription is map &&
             data.subscription.tier in ['free', 'pro', 'unlimited'] &&
             data.subscription.credits is number &&
             data.subscription.maxCredits is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId); 
      allow list: if false; 

      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
        // Action: Update Subscription
        incoming().diff(existing()).affectedKeys().hasOnly(['subscription']) ||
        // Action: Update Profile
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) ||
        // Action: Combined
        incoming().diff(existing()).affectedKeys().hasOnly(['subscription', 'displayName'])
      );
    }

    function isValidProject(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 256 &&
             data.originalPath is string && data.originalPath.size() <= 512 &&
             data.duration is number &&
             data.createdAt is number &&
             data.clips is list && data.clips.size() <= 100 &&
             data.activeTemplate is string;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && isValidId(projectId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) && 
                    incoming().userId == request.auth.uid;

      allow update: if isSignedIn() && isValidId(projectId) && 
                    existing().userId == request.auth.uid &&
                    isValidProject(incoming()) && 
                    incoming().userId == existing().userId &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['clips']) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['activeTemplate']) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['clips', 'activeTemplate', 'name'])
                    );

      allow delete: if isSignedIn() && isValidId(projectId) && existing().userId == request.auth.uid;
    }
  }
}
